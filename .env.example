# ─── Google Sheets RSVP storage ───────────────────────────────────────────
# Copy this file to `.env` and fill in the values. See the README for how to
# create the service account and share your sheet. If these are left unset,
# RSVPs are logged to the server console instead of written to a sheet.

# The service account's email (…@…iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# The service account's private key. Keep it on ONE line with literal "\n"
# escapes, wrapped in double quotes, exactly as it appears in the JSON key file:
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# The sheet id from its URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=

# ─── Password gate ─────────────────────────────────────────────────────────
# Signs the "unlocked" session cookie set after a guest enters the site
# password (see app/lib/auth.server.ts). Set this to any long random string
# in production — without it, sessions are signed with an insecure default
# and can be forged. Not required for local dev.
SESSION_SECRET=
